CONFIG_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$CONFIG_DIR/openwrt_autobuild.env" ]; then
    # Load shared mail notification settings.
    . "$CONFIG_DIR/openwrt_autobuild.env"
fi

MODEL_LINEUP=GDM7243ST
OS_PROJECT_NAME=uTKernel
OS_REPO_URL=https://jamesahn@vcs.gctsemi.com/OS/uTKernel
OS_REPO_BRANCH=
OS_PRODUCT_CONFIG=
OS_BUILD_VARIANT=gdm7243mt_32mb_no_l2_vport14
OS_CONFIG_CMD='printf "27\n" | make config && sleep 5'
OS_BUILD_CMD='make'
OS_REQUIRED_COMMANDS='git make armeb-4.8-linux-gcc'
OS_PATH_PREPEND=/opt/armeb-4.8/usr/bin
OS_LD_LIBRARY_PATH_PREPEND=/opt/armeb-4.8/usr/lib
