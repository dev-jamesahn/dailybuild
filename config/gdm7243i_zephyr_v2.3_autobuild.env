CONFIG_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$CONFIG_DIR/openwrt_autobuild.env" ]; then
    # Load shared mail notification settings.
    . "$CONFIG_DIR/openwrt_autobuild.env"
fi

MODEL_LINEUP=GDM7243i
OS_PROJECT_NAME=zephyr-v2.3
OS_REPO_URL=https://jamesahn@vcs.gctsemi.com/OS/zephyr-v2.3
OS_REPO_BRANCH=
OS_PRODUCT_CONFIG=
OS_BUILD_VARIANT=gdm7243i_nbiot_ntn_quad
OS_CONFIG_CMD=
OS_BUILD_CMD='source ./build_config.sh <<< "3" && sleep 5 && (ninja || ninja)'
OS_REQUIRED_COMMANDS='git ninja'
