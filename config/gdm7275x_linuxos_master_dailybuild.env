CONFIG_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$CONFIG_DIR/openwrt_dailybuild.env" ]; then
    # Load shared mail notification settings.
    . "$CONFIG_DIR/openwrt_dailybuild.env"
fi

MODEL_LINEUP=GDM7275X
OS_PROJECT_NAME=Linuxos
OS_REPO_URL=https://release.gctsemi.com/linuxos
OS_REPO_BRANCH=master
OS_PRODUCT_CONFIG=
OS_BUILD_VARIANT=master
OS_TARGET_NAME='GDM7275X Linuxos master'
OS_CONFIG_CMD=
OS_CONFIG_EXPECT_CHOICES='11 1 1'
OS_BUILD_CMD='make || make V=sc'
OS_REQUIRED_COMMANDS='git make expect'
OS_PATH_PREPEND=/opt/arm64v8el-9.3-uclibc/usr/bin
