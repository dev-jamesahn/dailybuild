CONFIG_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$CONFIG_DIR/openwrt_dailybuild.env" ]; then
    # Load shared mail notification settings.
    . "$CONFIG_DIR/openwrt_dailybuild.env"
fi

MODEL_LINEUP=GDM7243A
OS_PROJECT_NAME=uTKernel
OS_REPO_URL=https://jamesahn@vcs.gctsemi.com/OS/uTKernel
OS_REPO_BRANCH=
OS_PRODUCT_CONFIG=
OS_BUILD_VARIANT=gdm7243a_no_l2
OS_CONFIG_CMD='printf "1\n" | make config && sleep 5'
OS_BUILD_CMD='make'
OS_REQUIRED_COMMANDS='git make armel-v7-6.1-linux-gcc'
OS_PATH_PREPEND=/opt/armel-v7-6.1/usr/bin
OS_LD_LIBRARY_PATH_PREPEND=/opt/armel-v7-6.1/usr/lib
